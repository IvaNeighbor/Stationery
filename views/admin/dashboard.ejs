<div class="container admin-page">
  <div
    style="
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 30px 0;
    "
  >
    <h1 class="admin-title">Керування товарами</h1>

    <form action="/admin" method="GET" class="admin-search-form">
      <div class="admin-search-wrapper">
        <input
          type="text"
          name="search"
          placeholder="Пошук за назвою..."
          value="<%= query.search || '' %>"
          class="admin-search-input"
        />
        <% if (query.search) { %>
        <a href="/admin" class="admin-search-clear">&times;</a>
        <% } %>
      </div>
      <button type="submit" class="admin-search-btn">ЗНАЙТИ</button>
    </form>

    <a
      href="/admin/add"
      class="btn-confirm"
      style="width: auto; padding: 10px 20px; margin-top: 0"
      >+ Додати товар</a
    >
  </div>

  <% if (products.length > 0) { %>
  <table class="cart-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Фото</th>
        <th>Назва</th>
        <th>Бренд</th>
        <th>Ціна</th>
        <th style="text-align: center">Дії</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(p => { %>
      <tr>
        <td><%= p.id %></td>
        <td>
          <img src="<%= p.image %>" width="40" style="border-radius: 4px" />
        </td>
        <td><%= p.name %></td>
        <td><%= p.brand %></td>
        <td>
          <strong
            ><%= p.price %>
            ₴</strong
          >
        </td>
        <td>
          <div class="admin-actions">
            <a
              href="/admin/edit/<%= p.id %>"
              class="action-link edit"
              title="Редагувати"
              >✏️</a
            >
            <form
              action="/admin/delete/<%= p.id %>"
              method="POST"
              onsubmit="return confirm('Видалити цей товар?');"
            >
              <button type="submit" class="action-link delete" title="Видалити">
                🗑️
              </button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
  <!-- Блок, якщо результатів немає -->
  <div class="cart-empty" style="box-shadow: none; background: transparent">
    <div class="cart-empty__icon" style="font-size: 60px">🔍</div>
    <h2 class="cart-empty__title">Нічого не знайдено</h2>
    <p class="cart-empty__text">
      За запитом "<strong><%= query.search %></strong>" товарів не знайдено у
      вашій базі.
    </p>
    <a
      href="/admin"
      class="btn-confirm"
      style="display: inline-block; width: auto; padding: 12px 30px"
    >
      Скинути фільтри
    </a>
  </div>
  <% } %>
</div>
