<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Блок бренду -->
      <div class="footer__column footer__column--brand">
        <a href="/" class="footer__logo">
          <img src="/images/logo.svg" alt="КанцСвіт" />
        </a>
        <p class="footer__text">
          Твій надійний провідник у світі канцелярії для школи та офісу.
        </p>
      </div>

      <!-- Блок навігації -->
      <div class="footer__column">
        <h4 class="footer__title">Категорії</h4>
        <ul class="footer__list">
          <% categories.slice(0, 4).forEach(category => { %>
          <li>
            <a href="/category/<%= category.slug %>" class="footer__link">
              <%= category.name %>
            </a>
          </li>
          <% }); %>
        </ul>
      </div>

      <!-- Блок контактів -->
      <div class="footer__column">
        <h4 class="footer__title">Контакти</h4>
        <ul class="footer__list">
          <li>м. Суми, вул. Римського-Корсакова, 2</li>
          <li>
            <a href="mailto:info@kancsvit.ua" class="footer__link"
              >info@kancsvit.ua</a
            >
          </li>
          <li>+38 (0542) 12-34-56</li>
        </ul>
      </div>
    </div>
  </div>
</footer>
