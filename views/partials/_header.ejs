                  <div class="dropdown-menu__image">
                    <img src="/images/categories/pen.png" alt="Елітні ручки" />
                  </div>
                  <span class="dropdown-menu__title">Елітні ручки</span>
                </a>

                <a
                  href="/category/gifts/board-games"
                  class="dropdown-menu__item"
                >
                  <div class="dropdown-menu__image">
                    <img
