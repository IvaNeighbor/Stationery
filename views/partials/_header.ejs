                  <div class="dropdown-menu__image">
                    <img src="/images/categories/pen.png" alt="Рюкзаки" />
                  </div>
                  <span class="dropdown-menu__title">Рюкзаки</span>
                </a>

                <a
                  href="/category/school/pencil-cases"
                  class="dropdown-menu__item"
                >
                  <div class="dropdown-menu__image">
                    <img src="/images/categories/pen.png" alt="Пенали" />
                  </div>
                  <span class="dropdown-menu__title">Пенали</span>
                </a>

                <a href="/category/school/diaries" class="dropdown-menu__item">
                  <div class="dropdown-menu__image">
                    <img src="/images/categories/pen.png" alt="Щоденники" />
                  </div>
                  <span class="dropdown-menu__title">Щоденники</span>
                </a>

                <a
                  href="/category/school/drawing-sets"
                  class="dropdown-menu__item"
                >
                  <div class="dropdown-menu__image">
                    <img
                      src="/images/categories/pen.png"
                      alt="Набори для креслення"
                    />
                  </div>
                  <span class="dropdown-menu__title">Набори для креслення</span>
                </a>
              </div>
