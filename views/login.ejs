<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">Вхід</h1>
    <form action="/login" method="POST" class="auth-form">
      <div class="form-group">
        <label for="email">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          required
          placeholder="example@mail.com"
        />
      </div>
      <div class="form-group">
        <label for="password">Пароль</label>
        <input
          type="password"
          name="password"
          id="password"
          required
          placeholder="••••••••"
        />
      </div>
      <button type="submit" class="btn-auth">Увійти</button>
    </form>
    <p class="auth-footer">
      Немає акаунту? <a href="/register">Зареєструватися</a>
    </p>
  </div>
</div>
